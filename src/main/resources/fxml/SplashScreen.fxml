<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="splash-root"
           prefWidth="520" prefHeight="380">
    <VBox alignment="CENTER" spacing="10">

        <!-- Logo de la quincaillerie -->
        <ImageView fitWidth="150" fitHeight="150" preserveRatio="true" smooth="true">
            <image>
                <Image url="@../images/logo.png"/>
            </image>
        </ImageView>

        <Label text="StockManager CI" styleClass="splash-title"/>
        <Label text="Gestion des Stocks — Commerce Ivoirien" styleClass="splash-subtitle"/>
        <Label text="INP-HB · Département Informatique · IC-GL PROMO-2024"
               styleClass="splash-info"/>
        <Label text="v1.0" styleClass="splash-version"/>
        <ProgressBar prefWidth="300" progress="-1" styleClass="splash-progress"/>

    </VBox>
</StackPane>
