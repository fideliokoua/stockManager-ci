<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.inphb.icgl</groupId>
    <artifactId>stockmanager-ci</artifactId>
    <version>1.0.0</version>  <!-- ✅ Changé de 1.0-SNAPSHOT à 1.0.0 pour la production -->
    <name>StockManager CI</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <junit.version>5.12.1</junit.version>
        <javafx.version>25</javafx.version>  <!-- ✅ Version centralisée -->
        <main.class>com.inphb.icgl.stocks.MainApp</main.class>  <!-- ✅ Classe principale centralisée -->
    </properties>

    <dependencies>

        <!-- JavaFX -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- Driver JDBC MySQL 8 -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>8.0.33</version>
            <scope>compile</scope>
        </dependency>

        <!-- Apache POI — export XLSX -->
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-ooxml</artifactId>
            <version>5.2.5</version>
        </dependency>

        <!-- iTextPDF — export PDF -->
        <dependency>
            <groupId>com.itextpdf</groupId>
            <artifactId>itextpdf</artifactId>
            <version>5.5.13.3</version>
        </dependency>

        <!-- JUnit 5 — tests unitaires -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!-- ✅ 1. Compilation Java 21 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>25</source>
                    <target>25</target>
                </configuration>
            </plugin>

            <!-- ✅ 2. Plugin JavaFX (pour lancer avec mvn javafx:run) -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>${main.class}</mainClass>
                    <options>
                        <option>--enable-native-access=javafx.graphics</option>
                        <option>--enable-native-access=javafx.base</option>
                        <option>--enable-native-access=ALL-UNNAMED</option>
                    </options>

                </configuration>
            </plugin>

            <!-- ✅ 3. Création du JAR exécutable (Fat JAR) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>${main.class}</mainClass>
                                </transformer>
                                <!-- ✅ Nécessaire pour Apache POI -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.AppendingTransformer">
                                    <resource>META-INF/spring.handlers</resource>
                                </transformer>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <!-- ✅ Exclure les signatures pour éviter les erreurs -->
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                            <outputFile>
                                ${project.build.directory}/stockmanager-ci-1.0.jar
                            </outputFile>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- ✅ 4. Plugin jpackage — création du .dmg macOS -->
            <plugin>
                <groupId>org.panteleyev</groupId>
                <artifactId>jpackage-maven-plugin</artifactId>
                <version>1.6.5</version>
                <configuration>
                    <!-- Type d'installeur -->
                    <type>DMG</type>

                    <!-- Infos application -->
                    <name>StockManager CI</name>
                    <appVersion>${project.version}</appVersion>
                    <vendor>INPHB IC-GL</vendor>
                    <copyright>2026 INPHB IC-GL</copyright>

                    <!-- JAR source -->
                    <input>${project.build.directory}</input>
                    <mainJar>stockmanager-ci-1.0.jar</mainJar>
                    <mainClass>${main.class}</mainClass>

                    <!-- Dossier de sortie -->
                    <destination>${project.build.directory}/installer</destination>

                    <!-- Icône macOS -->
                    <icon>src/main/resources/icons/stockmanager.icns</icon>

                    <!-- Options JVM -->
                    <javaOptions>
                        <javaOption>-Dfile.encoding=UTF-8</javaOption>
                    </javaOptions>

                    <!-- Options spécifiques macOS -->
                    <macPackageName>StockManagerCI</macPackageName>
                    <macPackageIdentifier>com.inphb.icgl.stockmanager</macPackageIdentifier>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <useModulePath>false</useModulePath> <!-- ✅ Désactive le système de modules pour les tests -->
                    <argLine>
                        --add-opens com.inphb.icgl.stocks/com.inphb.icgl.stocks.dao=ALL-UNNAMED
                        --add-opens com.inphb.icgl.stocks/com.inphb.icgl.stocks.utils=ALL-UNNAMED
                        --add-opens com.inphb.icgl.stocks/com.inphb.icgl.stocks.model=ALL-UNNAMED
                        --add-opens com.inphb.icgl.stocks/com.inphb.icgl.stocks.repository=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>